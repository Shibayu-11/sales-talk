# SalesTalk environment variables — DEVELOPMENT ONLY.
# In production, secrets are stored in macOS Keychain via Electron safeStorage (PRD §20.2).
# Never commit a real .env file. Never bundle real keys into the app binary.

# ────────────────────────────────────────────────────────────
# STT — Deepgram Nova-3 (PRD §15)
# ────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=

# ────────────────────────────────────────────────────────────
# LLM — Anthropic (Haiku 4.5 detection + Sonnet 4.6 generation, PRD §16)
# ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_HAIKU_MODEL=claude-haiku-4-5
ANTHROPIC_SONNET_MODEL=claude-sonnet-4-6

# ────────────────────────────────────────────────────────────
# Embeddings — Cohere embed-v4 (1024 dims, MRL, PRD §17)
# ────────────────────────────────────────────────────────────
COHERE_API_KEY=
COHERE_EMBED_MODEL=embed-v4.0

# ────────────────────────────────────────────────────────────
# Database — Supabase (Tokyo ap-northeast-1, PRD §3.2b)
# ────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
# service_role MUST stay server-side (never bundle in app, never to renderer).
SUPABASE_SERVICE_ROLE_KEY=
# Tenant UUID used by Main process when querying RLS-protected knowledge tables.
SALES_TALK_TENANT_ID=

# ────────────────────────────────────────────────────────────
# Telemetry (PRD §20)
# ────────────────────────────────────────────────────────────
SENTRY_DSN=
POSTHOG_PROJECT_KEY=
POSTHOG_HOST=https://us.posthog.com

# ────────────────────────────────────────────────────────────
# Auto-update (PRD §32)
# ────────────────────────────────────────────────────────────
GH_TOKEN=

# ────────────────────────────────────────────────────────────
# Apple notarization (PRD §19)
# ────────────────────────────────────────────────────────────
APPLE_ID=
APPLE_APP_SPECIFIC_PASSWORD=
APPLE_TEAM_ID=

# ────────────────────────────────────────────────────────────
# Dev flags
# ────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
