{
  "name": "sales-talk",
  "version": "0.0.1",
  "private": true,
  "description": "Zoom video meeting realtime sales objection handling assistant for macOS",
  "main": "out/main/index.js",
  "author": "sales-talk",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "native:audio:build": "cd src/native/audio-capture && node-gyp rebuild",
    "native:audio:clean": "cd src/native/audio-capture && node-gyp clean",
    "native:audio:smoke": "tsx scripts/audio-capture-smoke.ts",
    "package:mac": "npm run native:audio:build && electron-vite build && electron-builder --mac --universal",
    "license:audit": "tsx scripts/license-audit.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@supabase/supabase-js": "^2.45.0",
    "@xstate/react": "^4.1.0",
    "clsx": "^2.1.1",
    "cohere-ai": "^7.13.0",
    "electron-updater": "^6.3.0",
    "pino": "^9.4.0",
    "puppeteer-core": "^23.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.0",
    "xstate": "^5.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^20.16.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.12",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "electron": "^32.1.0",
    "electron-builder": "^25.0.5",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "msw": "^2.4.0",
    "pino-pretty": "^11.2.2",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "^5.6.0",
    "vite": "^5.4.8",
    "vitest": "^2.1.0"
  }
}
